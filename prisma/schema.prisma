datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

enum PlayoffFormat {
  SINGLE_ELIM
  TWO_LEG
}

enum Role {
  ADMIN
  CAPTAIN
}

model User {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  role         Role
  teamId       String?  @unique
  team         Team?    @relation("TeamCaptain", fields: [teamId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
}

model League {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  playoffFormat    PlayoffFormat?
  playoffTeamCount Int?
  playoffSeeded    Boolean @default(true)

  teams          Team[]
  matches        Match[]
  playoffSeries  PlayoffSeries[]
}

model Team {
  id          String   @id @default(cuid())
  name        String
  badgeUrl    String?
  createdAt   DateTime @default(now())

  leagueId    String
  league      League   @relation(fields: [leagueId], references: [id], onDelete: Cascade)

  players     Player[]
  homeMatches Match[]  @relation("HomeTeam")
  awayMatches Match[]  @relation("AwayTeam")

  homeSeries  PlayoffSeries[] @relation("SeriesHome")
  awaySeries  PlayoffSeries[] @relation("SeriesAway")
  wonSeries   PlayoffSeries[] @relation("SeriesWinner")

  captain     User?           @relation("TeamCaptain")

  @@unique([leagueId, name])
}

model Player {
  id        String   @id @default(cuid())

  firstName String
  lastName  String
  number    Int
  position  String?
  photoUrl  String?

  teamId    String
  team      Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)

  stats     MatchPlayerStat[]

  @@index([teamId])
  @@unique([teamId, number])
}

model Match {
  id         String   @id @default(cuid())
  leagueId   String
  round      Int
  date       DateTime?

  homeTeamId String
  awayTeamId String

  homeGoals  Int?
  awayGoals  Int?

  seriesId   String?
  leg        Int?

  createdAt  DateTime @default(now())

  league     League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  homeTeam   Team   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeam   Team   @relation("AwayTeam", fields: [awayTeamId], references: [id])
  series     PlayoffSeries? @relation(fields: [seriesId], references: [id], onDelete: Cascade)

  stats      MatchPlayerStat[]

  @@index([leagueId, round])
  @@index([seriesId])
  @@unique([seriesId, leg])
}

model MatchPlayerStat {
  id       String @id @default(cuid())

  matchId  String
  playerId String

  goals    Int    @default(0)
  assists  Int    @default(0)

  match    Match  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player   Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([playerId])
}

model PlayoffSeries {
  id          String   @id @default(cuid())
  leagueId    String

  bracketRound  Int
  position      Int

  homeTeamId    String?
  awayTeamId    String?

  homeSeed      Int?
  awaySeed      Int?

  winnerId      String?

  feedsIntoSeriesId String?

  league     League @relation(fields: [leagueId], references: [id], onDelete: Cascade)
  homeTeam   Team?  @relation("SeriesHome", fields: [homeTeamId], references: [id])
  awayTeam   Team?  @relation("SeriesAway", fields: [awayTeamId], references: [id])
  winner     Team?  @relation("SeriesWinner", fields: [winnerId], references: [id])
  feedsInto  PlayoffSeries? @relation("BracketProgression", fields: [feedsIntoSeriesId], references: [id])

  feederSeries PlayoffSeries[] @relation("BracketProgression")
  matches      Match[]

  @@unique([leagueId, bracketRound, position])
  @@index([leagueId])
}
